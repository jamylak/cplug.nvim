{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug app",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "internalConsole"
    },
    {
      "name": "Debug current file",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "internalConsole"
    },
    {
      "name": "Attach debugpy",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "127.0.0.1",
        "port": 5678
      }
    }
  ]
}
